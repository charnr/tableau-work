          <datasource-dependencies datasource='federated.0zc1o901e3ofjl0zox69m0b5e5q7'>
            <column aggregation='CountD' caption='Won' datatype='string' default-role='measure' default-type='quantitative' name='[Calculation_1141943991684665345]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [iswon] = TRUE THEN [id] ELSE NULL END' />
            </column>
            <column caption='COUNTD([Won])/COUNTD([Id])' datatype='real' name='[Calculation_1141943991684743171]' role='measure' type='quantitative' user:unnamed='SEA Inbound Leads (2)'>
              <calculation class='tableau' formula='COUNTD([Calculation_1141943991684665345])/COUNTD([id])' />
            </column>
            <column caption='Allocated Date Only' datatype='date' name='[Calculation_131167342751051776]' role='dimension' type='ordinal'>
              <calculation class='tableau' formula='DATE([allocated_date_time])' />
