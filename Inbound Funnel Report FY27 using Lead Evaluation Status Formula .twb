            <column caption='RAB Exclude Blanks' datatype='string' name='[Calculation_845832326920331264]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Calculation_1032450282310459396] = &apos;Refer-a-friend&apos; AND [datatracker_source] = &quot;&quot;&#13;&#10;THEN &quot;Exclude&quot;&#13;&#10;ELSE &quot;Include&quot;&#13;&#10;END' />
