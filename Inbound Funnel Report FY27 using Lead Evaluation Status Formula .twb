            <column caption='Applied for Diesel LOD' datatype='integer' name='[Calculation_1032450282311340040]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED [id] :MAX([monthly_diesel])}' />
            </column>
            <column caption='Applied for Petrol LOD' datatype='integer' name='[Calculation_1032450282311401481]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED [id] :MAX([monthly_petrol])}' />
            </column>
            <column caption='Applied for Fuel' datatype='integer' name='[Calculation_1032450282311532554]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='[Calculation_1032450282311340040]+[Calculation_1032450282311401481]' />
            </column>
            <column caption='VIC' datatype='integer' name='[Calculation_1032450282311634955]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF [sales_sub_stage] = &quot;Closed Won&quot; THEN [Calculation_1032450282311532554] ELSE NULL END' />
            </column>
            <column caption='Allocated Date Only' datatype='date' name='[Calculation_131167342751051776]' role='dimension' type='ordinal'>
              <calculation class='tableau' formula='DATE([allocated_date_time])' />
            </column>
            <column caption='Lead Record Type inc BP' datatype='string' name='[Calculation_1394708576190578690]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [lead channel] = &quot;3rd Party Provider&quot; AND [lead sub channel] = &quot;BP&quot; THEN &quot;Fuel (Inbound)&quot;&#13;&#10;ELSEIF [lead sub channel] = &quot;Radiuscompare.com&quot; THEN &quot;Fuel (Inbound)&quot;&#13;&#10;ELSE [record_type] END' />
            </column>
            <column caption='Ireland Lead Channel Fix' datatype='string' name='[Calculation_1427078138646933504]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF UPPER([datatracker_source]) = &quot;BROKER MVF FUEL CARD&quot; THEN &quot;MVF&quot;&#13;&#10;ELSEIF UPPER([lead channel]) = &quot;3RD PARTY PROVIDER&quot; THEN [lead sub channel]&#13;&#10;ELSEIF UPPER([lead channel]) = &quot;INBOUND&quot; AND [datatracker_source] = &quot;&quot; THEN &quot;Inbound (Call/Email)&quot;&#13;&#10;ELSEIF CONTAINS(UPPER([datatracker_source]),&quot;REFERRAL&quot;) THEN &quot;Referral&quot;&#13;&#10;ELSEIF CONTAINS(UPPER([lead channel]),&quot;REFERRAL&quot;) THEN &quot;Referral&quot;&#13;&#10;ELSEIF CONTAINS([lead sub channel],&quot;iCompario&quot;) THEN &quot;iCompario&quot;&#13;&#10;ELSEIF CONTAINS([datatracker_source],&quot;iCompario&quot;) THEN &quot;iCompario&quot;&#13;&#10;ELSEIF [lead channel] = &quot;Website&quot; THEN [lead sub channel]&#13;&#10;ELSEIF CONTAINS (UPPER([datatracker_source]),&quot;DCI&quot;) THEN &quot;dcicard.com&quot;&#13;&#10;ELSE [lead channel] END' />
            </column>
            <column caption='Ireland Business?' datatype='string' name='[Calculation_1427078138652413954]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [legal_entity]= &quot;Individual&quot; THEN &quot;No&quot;&#13;&#10;ELSEIF [legal_entity] = &quot;Not Stated&quot; THEN &quot;Not Stated&quot;&#13;&#10;ELSEIF [legal_entity] = &quot;&quot; THEN &quot;Not Stated&quot;&#13;&#10;ELSE &quot;Yes&quot; END' />
            </column>
            <column caption='Lead Created Date' datatype='date' name='[Calculation_165225817733201924]' role='dimension' type='ordinal'>
              <calculation class='tableau' formula='DATE([createddate])' />
            </column>
            <column datatype='string' name='[Datatracker Track Source (group)]' role='dimension' type='nominal'>
