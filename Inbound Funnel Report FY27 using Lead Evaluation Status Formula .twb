            <column caption='Lead Created Date' datatype='date' name='[Calculation_165225817733201924]' role='dimension' type='ordinal'>
              <calculation class='tableau' formula='DATE([createddate])' />
            </column>
            <column caption='Crewe Inbound/Ipswich - Receiver Team' datatype='string' name='[Calculation_1686598103065382912]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [lead_owner_manager] IN (&quot;Lee Armstrong&quot;, &quot;Rob Scragg&quot;)&#13;&#10;THEN &quot;Crewe - Inbound&quot;&#13;&#10;ELSEIF ZN(INT([employee_id])) = 4918 &#13;&#10;OR ZN(INT([employee_id])) = 10689 &#13;&#10;OR ZN(INT([employee_id])) = 196 &#13;&#10;OR ZN(INT([employee_id])) = 6179&#13;&#10;THEN &quot;Ipswich - Receiver Team&quot;&#13;&#10;END' />
            </column>
            <column caption='Legal Entity RBS Fix' datatype='string' name='[Calculation_551690994224705536]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF CONTAINS(UPPER([description]), &apos;BUSINESS OWNER: NO&apos;) THEN &apos;Individual&apos;&#13;&#10;ELSEIF CONTAINS(UPPER([description]), &apos;BUSINESS OWNER: TIDAK&apos;) THEN &apos;Individual&apos;&#13;&#10;ELSE [legal_entity] END' />
            </column>
            <column aggregation='Sum' caption='MQL' datatype='integer' name='[Marketing Qualified Lead? (copy)_1607222149788565505]' role='dimension' type='ordinal'>
              <calculation class='tableau' formula='IF [Calculation_551690994224705536] = &apos;Individual&apos; AND [status] = &apos;Closed&apos; THEN 0&#13;&#10;ELSEIF [lead evaluation status formula] = &quot;MQL&quot; AND NOT UPPER([radius sales type]) = (&quot;UPSELL BUSINESS&quot;) THEN  1&#13;&#10;ELSE 0&#13;&#10;END' />
            </column>
            <column caption='Allocated Date Time' datatype='datetime' name='[allocated_date_time]' role='dimension' type='ordinal' />
