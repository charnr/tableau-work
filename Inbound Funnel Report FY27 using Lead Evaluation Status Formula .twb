        <calculation class='tableau' formula='CASE LOWER(TRIM([name]))&#13;&#10;WHEN &quot;aaron crowe&quot; THEN 14754&#13;&#10;WHEN &quot;adam lawlor smalle&quot; THEN 13163&#13;&#10;WHEN &quot;alan drewery&quot; THEN 10884&#13;&#10;WHEN &quot;alex alabih&quot; THEN 12184&#13;&#10;WHEN &quot;alex gorman&quot; THEN 13004&#13;&#10;WHEN &quot;alex wood&quot; THEN 11752&#13;&#10;WHEN &quot;alfie clayton&quot; THEN 13333&#13;&#10;WHEN &quot;ali razza&quot; THEN 13525&#13;&#10;WHEN &quot;andrew powell&quot; THEN 9274&#13;&#10;WHEN &quot;andrew whiteside&quot; THEN 14564&#13;&#10;WHEN &quot;andy burn&quot; THEN 11065&#13;&#10;WHEN &quot;andy taylor&quot; THEN 14240&#13;&#10;WHEN &quot;andzelika vaskeviciute&quot; THEN 5749&#13;&#10;WHEN &quot;anita small&quot; THEN 6497&#13;&#10;WHEN &quot;ashaya tracey&quot; THEN 12353&#13;&#10;WHEN &quot;ashley jordan&quot; THEN 10057&#13;&#10;WHEN &quot;babajide idowu&quot; THEN 13966&#13;&#10;WHEN &quot;bailey postlethwaite&quot; THEN 14475&#13;&#10;WHEN &quot;bel rodrigues&quot; THEN 13561&#13;&#10;WHEN &quot;ben gregory&quot; THEN 14154&#13;&#10;WHEN &quot;ben hardy&quot; THEN 15042&#13;&#10;WHEN &quot;ben kennell&quot; THEN 14872&#13;&#10;WHEN &quot;benji cole&quot; THEN 13401&#13;&#10;WHEN &quot;bliain feeney&quot; THEN 13935&#13;&#10;WHEN &quot;brad camilleri&quot; THEN 13558&#13;&#10;WHEN &quot;brad mcseveney&quot; THEN 14556&#13;&#10;WHEN &quot;brandan bradley&quot; THEN 14006&#13;&#10;WHEN &quot;brandon matthews&quot; THEN 7984&#13;&#10;WHEN &quot;cameron carruthers&quot; THEN 14387&#13;&#10;WHEN &quot;caolan mcglinchey&quot; THEN 12727&#13;&#10;WHEN &quot;caroline holland&quot; THEN 13491&#13;&#10;WHEN &quot;cashel cooper-kelly&quot; THEN 15041&#13;&#10;WHEN &quot;chandon itburrun&quot; THEN 15007&#13;&#10;WHEN &quot;charlie nhindiri&quot; THEN 13818&#13;&#10;WHEN &quot;chloe denny&quot; THEN 12788&#13;&#10;WHEN &quot;chloe howard&quot; THEN 3798&#13;&#10;WHEN &quot;chris dumigan&quot; THEN 15035&#13;&#10;WHEN &quot;chris ke