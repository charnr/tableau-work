            <column aggregation='Sum' caption='MQL' datatype='integer' name='[Marketing Qualified Lead? (copy)_1607222149788565505]' role='dimension' type='ordinal'>
              <calculation class='tableau' formula='IF [Calculation_551690994224705536] = &apos;Individual&apos; AND [status] = &apos;Closed&apos; THEN 0&#13;&#10;ELSEIF [lead evaluation status formula] = &quot;MQL&quot; AND NOT UPPER([radius sales type]) = (&quot;UPSELL BUSINESS&quot;) THEN  1&#13;&#10;ELSE 0&#13;&#10;END' />
            </column>
            <column caption='Country Iso Code' datatype='string' name='[country_iso_code]' role='dimension' semantic-role='[Country].[ISO3166_2]' type='nominal' />
