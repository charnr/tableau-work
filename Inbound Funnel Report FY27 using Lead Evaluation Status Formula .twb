      <aliases enabled='yes' />
      <column datatype='string' name='[:Measure Names]' role='dimension' type='nominal'>
        <aliases>
          <alias key='&quot;[federated.0zc1o901e3ofjl0zox69m0b5e5q7].[pcto:ctd:Calculation_1141943991684628480:qk:1]&quot;' value='% of Leads' />
          <alias key='&quot;[federated.0zc1o901e3ofjl0zox69m0b5e5q7].[usr:Calculation_1141943991684743171:qk]&quot;' value='MQL Conv %' />
        </aliases>
      </column>
      <column caption='Allocated Date (Working Days Fix)' datatype='datetime' name='[Calculation_1032450282305802241]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='IF DATEPART(&apos;weekday&apos;, [allocated_date_time]) = 1&#13;&#10;THEN DATEADD(&apos;day&apos;, -2, [allocated_date_time])&#13;&#10;ELSEIF DATEPART(&apos;weekday&apos;, [allocated_date_time]) = 7&#13;&#10;THEN DATEADD(&apos;day&apos;, -1, [allocated_date_time])&#13;&#10;ELSE [allocated_date_time]&#13;&#10;END' />
      </column>
      <column caption='UK Lead Channel Fix' datatype='string' name='[Calculation_1032450282310459396]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [lead channel] = &quot;3rd Party Provider&quot; THEN [lead sub channel]&#13;&#10;ELSEIF [lead channel]  = &quot;Social Media&quot; THEN  [lead sub channel]&#13;&#10;ELSEIF CONTAINS(UPPER([datatracker_source]),&quot;RADIUS.COM&quot;) THEN &quot;radius.com&quot;&#13;&#10;ELSEIF UPPER([lead channel]) = &quot;INBOUND&quot; THEN &quot;Inbound (Call/Email)&quot;&#13;&#10;ELSEIF UPPER([lead channel]) = &quot;WEBSITE&quot; Then [lead sub channel]&#13;&#10;ELSE [lead channel] END' />
      </column>
      <column caption='Applied for Diesel LOD' datatype='integer' name='[Calculation_1032450282311340040]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [id] :MAX([monthly_diesel])}' />
      </column>
      <column caption='Applied for Petrol LOD' datatype='integer' name='[Calculation_1032450282311401481]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [id] :MAX([monthly_petrol])}' />
      </column>
      <column caption='Applied for Fuel' datatype='integer' name='[Calculation_1032450282311532554]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_1032450282311340040]+[Calculation_1032450282311401481]' />
      </column>
      <column caption='VIC' datatype='integer' name='[Calculation_1032450282311634955]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [sales_sub_stage] = &quot;Closed Won&quot; THEN [Calculation_1032450282311532554] ELSE NULL END' />
      </column>
      <column caption='Duplicate Lead?' datatype='string' name='[Calculation_1032450282325688334]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [status] = &quot;Closed&quot; AND [reject_reason] = &quot;Duplicate Record&quot;&#13;&#10;AND [duplicate_of_account] &lt;&gt; &quot;&quot;&#13;&#10;THEN &quot;Automatic Dupe&quot;&#13;&#10;ELSEIF [status] = &quot;Closed&quot; AND [reject_reason] = &quot;Duplicate Record&quot;&#13;&#10;AND [duplicate_of_opportunity] &lt;&gt; &quot;&quot;&#13;&#10;THEN &quot;Automatic Dupe&quot;&#13;&#10;ELSEIF [status] = &quot;Closed&quot; AND [reject_reason] = &quot;Duplicate Record&quot;&#13;&#10;AND [duplicate_of_lead] &lt;&gt; &quot;&quot;&#13;&#10;THEN &quot;Automatic Dupe&quot;&#13;&#10;ELSE NULL END' />
      </column>
      <column caption='ID %' datatype='string' name='[Calculation_1141943991684628480]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[id]' />
      </column>
      <column aggregation='CountD' caption='Won' datatype='string' default-role='measure' default-type='quantitative' name='[Calculation_1141943991684665345]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [iswon] = TRUE THEN [id] ELSE NULL END' />
      </column>
      <column caption='Channel' datatype='string' name='[Calculation_1141943991701549060]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [lead channel] IN (&apos;3rd Party Provider&apos;,&apos;Website&apos;)&#13;&#10;THEN [lead sub channel] &#13;&#10;ELSE [lead channel] END' />
      </column>
      <column aggregation='Sum' caption='Verified Lead? old' datatype='integer' name='[Calculation_1182194924152467462]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='IF [radius sales type] = &apos;Upsell Business&apos; THEN 0&#13;&#10;ELSEIF [radius sales type] = &apos;Existing Business&apos; THEN 0&#13;&#10;ELSEIF LOWER([status]) = &apos;closed&apos; AND LOWER([reject_reason]) = &apos;duplicate record&apos;&#13;&#10;   AND (&#13;&#10;   (NOT ISNULL([duplicate_of_account]) AND TRIM([duplicate_of_account]) &lt;&gt; &quot;&quot;) OR&#13;&#10;   (NOT ISNULL([duplicate_of_opportunity]) AND TRIM([duplicate_of_opportunity]) &lt;&gt; &quot;&quot;) OR&#13;&#10;   (NOT ISNULL([duplicate_of_lead]) AND TRIM([duplicate_of_lead]) &lt;&gt; &quot;&quot;)&#13;&#10;)&#13;&#10;THEN 0&#13;&#10;&#13;&#10;ELSEIF LOWER([status]) = &apos;closed&apos; AND&#13;&#10;( LOWER([reject_disposition]) = &apos;completed application&apos; OR &#13;&#10;LOWER([reject_disposition]) = &apos;existing customer&apos; OR &#13;&#10;LOWER([reject_disposition]) = &apos;existing prospect&apos;)&#13;&#10;  &#13;&#10;&#13;&#10;   AND (&#13;&#10;   (NOT ISNULL([duplicate_of_account]) AND TRIM([duplicate_of_account]) &lt;&gt; &quot;&quot;) OR&#13;&#10;   (NOT ISNULL([duplicate_of_opportunity]) AND TRIM([duplicate_of_opportunity]) &lt;&gt; &quot;&quot;) OR&#13;&#10;   (NOT ISNULL([duplicate_of_lead]) AND TRIM([duplicate_of_lead]) &lt;&gt; &quot;&quot;)&#13;&#10;)&#13;&#10;&#13;&#10;THEN 0&#13;&#10;ELSE 1&#13;&#10;END' />
      </column>
      <column caption='Lead Channel' datatype='string' name='[Calculation_124130531393454080]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [id] = &quot;00Q8e000007x8jeEAA&quot; THEN &quot;Inbound (Call/Email/Website)&quot;&#13;&#10;ELSEIF [lead channel] = &quot;3rd Party Provider&quot; THEN [lead sub channel]&#13;&#10;ELSEIF CONTAINS(UPPER([datatracker_source]),&quot;RADIUS.COM&quot;) THEN &quot;radius.com&quot;&#13;&#10;ELSEIF UPPER([lead channel]) = &quot;INBOUND&quot; THEN &quot;Inbound (Call/Email/Website)&quot;&#13;&#10;ELSEIF UPPER([lead channel]) = &quot;WEBSITE&quot; Then [lead sub channel]&#13;&#10;ELSE [lead channel] END' />
        <aliases>
          <alias key='&quot;Europeandieselcard.com&quot;' value='EDC' />
          <alias key='&quot;Inbound (Call/Email/Website)&quot;' value='Inbound' />
        </aliases>
      </column>
      <column caption='Lead Channel Filter' datatype='string' name='[Calculation_124130531394502657]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[Calculation_124130531393454080]' />
      </column>
      <column caption='ISOWeek of Reporting Day' datatype='string' name='[Calculation_124130531396517890]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='str(datepart(&apos;year&apos;, dateadd(&apos;week&apos;, INT(datediff(&apos;day&apos;, #1900-1-1#,[Calculation_1394708576197808136])/7), #1900-1-4#)))+ &#13;&#10;IF INT((Datepart(&apos;dayofyear&apos;, (dateadd(&apos;day&apos;,INT(datediff(&apos;day&apos;, #1900-1-01#, [Calculation_1394708576197808136])/7)*7  + 3,#1900-1-01#))) + 6)/7) &lt; 10 THEN&#13;&#10;    &apos;0&apos;&#13;&#10;ELSE&#13;&#10;    &apos;&apos;&#13;&#10;END +&#13;&#10;str(INT((Datepart(&apos;dayofyear&apos;, (dateadd(&apos;day&apos;,INT(datediff(&apos;day&apos;, #1900-1-01#, [Calculation_1394708576197808136])/7)*7  + 3,#1900-1-01#))) + 6)/7))' />
      </column>
      <column caption='Allocated Date Only' datatype='date' name='[Calculation_131167342751051776]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='DATE([allocated_date_time])' />
      </column>
      <column caption='Lead Record Type inc BP' datatype='string' name='[Calculation_1394708576190578690]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [lead channel] = &quot;3rd Party Provider&quot; AND [lead sub channel] = &quot;BP&quot; THEN &quot;Fuel (Inbound)&quot;&#13;&#10;ELSEIF [lead sub channel] = &quot;Radiuscompare.com&quot; THEN &quot;Fuel (Inbound)&quot;&#13;&#10;ELSE [record_type] END' />
      </column>
      <column caption='Create Hour' datatype='integer' name='[Calculation_1394708576197513219]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='DATEPART(&apos;hour&apos;,[createddate])*60 + DATEPART(&apos;minute&apos;,[createddate])' />
      </column>
      <column caption='Day +1' datatype='datetime' name='[Calculation_1394708576197689349]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='DATEADD(&apos;day&apos;,1,[createddate])' />
      </column>
      <column caption='Day +2' datatype='datetime' name='[Calculation_1394708576197730310]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='DATEADD(&apos;day&apos;,2, [createddate])' />
      </column>
      <column caption='Day +3' datatype='datetime' name='[Calculation_1394708576197779463]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='DATEADD(&apos;day&apos;,3,[createddate])' />
      </column>
      <column caption='Reporting Day' datatype='datetime' datatype-customized='true' name='[Calculation_1394708576197808136]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='IF ISOWEEKDAY([createddate]) = 5 AND [Calculation_1394708576197513219] &gt;=960 THEN [Calculation_1394708576197779463] ELSEIF&#13;&#10;ISOWEEKDAY([createddate]) = 5 AND [Calculation_1394708576197513219] &lt;450 THEN [createddate] ELSEIF&#13;&#10;ISOWEEKDAY([createddate]) = 6 THEN [Calculation_1394708576197730310] ELSEIF&#13;&#10;ISOWEEKDAY([createddate]) = 7 THEN [Calculation_1394708576197689349] ELSEIF &#13;&#10;ISOWEEKDAY([createddate]) = 1 AND [Calculation_1394708576197513219] &lt;450 THEN [createddate] ELSEIF&#13;&#10;ISOWEEKDAY([createddate]) = 1 AND [Calculation_1394708576197513219] &gt;=960 THEN [Calculation_1394708576197689349] ELSEIF&#13;&#10;ISOWEEKDAY([createddate]) = 2 AND [Calculation_1394708576197513219] &gt;=960 THEN [Calculation_1394708576197689349] ELSEIF&#13;&#10;ISOWEEKDAY([createddate]) = 3 AND [Calculation_1394708576197513219] &gt;=960 THEN [Calculation_1394708576197689349] ELSEIF&#13;&#10;ISOWEEKDAY([createddate]) = 4 AND [Calculation_1394708576197513219] &gt;=960 THEN [Calculation_1394708576197689349] ELSEIF&#13;&#10;ISOWEEKDAY([createddate]) = 2  AND [Calculation_1394708576197513219] &lt;450 THEN [createddate] ELSEIF&#13;&#10;ISOWEEKDAY([createddate]) = 3  AND [Calculation_1394708576197513219] &lt;450 THEN [createddate] ELSEIF&#13;&#10;ISOWEEKDAY([createddate]) = 4  AND [Calculation_1394708576197513219] &lt;450 THEN [createddate] &#13;&#10;ELSE [createddate] END' />
      </column>
      <column caption='WoW Calc Filter' datatype='boolean' name='[Calculation_1394708576218345481]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='DATETRUNC(&apos;week&apos;,[Calculation_1394708576197808136]) = DATETRUNC(&apos;week&apos;,TODAY())&#13;&#10;&#13;&#10;OR&#13;&#10;&#13;&#10;DATETRUNC(&apos;week&apos;,[Calculation_1394708576197808136]) = DATETRUNC(&apos;week&apos;,DATEADD(&apos;week&apos;,-1,TODAY()))' />
      </column>
      <column caption='Exclude Current Week' datatype='string' name='[Calculation_1394708576218456074]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF ISOWEEK([Calculation_1394708576197808136]) = ISOWEEK(TODAY()) THEN &quot;Exclude&quot;&#13;&#10;ELSE &quot;Include&quot;&#13;&#10;END' />
      </column>
      <column caption='YoY Calc Filter' datatype='boolean' name='[Calculation_1394708576219205647]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='DATETRUNC(&apos;year&apos;,[Calculation_1394708576197808136]) = DATETRUNC(&apos;year&apos;,TODAY())&#13;&#10;AND&#13;&#10;DATETRUNC(&apos;week&apos;,[Calculation_1394708576197808136]) = DATETRUNC(&apos;week&apos;,TODAY())&#13;&#10;&#13;&#10;OR&#13;&#10;&#13;&#10;DATETRUNC(&apos;year&apos;,[Calculation_1394708576197808136]) = DATETRUNC(&apos;year&apos;,DATEADD(&apos;year&apos;,-1,TODAY()))&#13;&#10;AND&#13;&#10;DATETRUNC(&apos;week&apos;,[Calculation_1394708576197808136]) = DATETRUNC(&apos;week&apos;,DATEADD(&apos;year&apos;,-1,TODAY()))' />
      </column>
      <column caption='Exclude Current Year' datatype='string' name='[Calculation_1394708576219316240]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF YEAR([Calculation_1394708576197808136]) = YEAR(TODAY()) THEN &quot;Exclude&quot; ELSE &quot;Include&quot; END' />
      </column>
      <column caption='Ireland Lead Channel Fix' datatype='string' name='[Calculation_1427078138646933504]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF UPPER([datatracker_source]) = &quot;BROKER MVF FUEL CARD&quot; THEN &quot;MVF&quot;&#13;&#10;ELSEIF UPPER([lead channel]) = &quot;3RD PARTY PROVIDER&quot; THEN [lead sub channel]&#13;&#10;ELSEIF UPPER([lead channel]) = &quot;INBOUND&quot; AND [datatracker_source] = &quot;&quot; THEN &quot;Inbound (Call/Email)&quot;&#13;&#10;ELSEIF CONTAINS(UPPER([datatracker_source]),&quot;REFERRAL&quot;) THEN &quot;Referral&quot;&#13;&#10;ELSEIF CONTAINS(UPPER([lead channel]),&quot;REFERRAL&quot;) THEN &quot;Referral&quot;&#13;&#10;ELSEIF CONTAINS([lead sub channel],&quot;iCompario&quot;) THEN &quot;iCompario&quot;&#13;&#10;ELSEIF CONTAINS([datatracker_source],&quot;iCompario&quot;) THEN &quot;iCompario&quot;&#13;&#10;ELSEIF [lead channel] = &quot;Website&quot; THEN [lead sub channel]&#13;&#10;ELSEIF CONTAINS (UPPER([datatracker_source]),&quot;DCI&quot;) THEN &quot;dcicard.com&quot;&#13;&#10;ELSE [lead channel] END' />
      </column>
      <column caption='Ireland Business?' datatype='string' name='[Calculation_1427078138652413954]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [legal_entity]= &quot;Individual&quot; THEN &quot;No&quot;&#13;&#10;ELSEIF [legal_entity] = &quot;Not Stated&quot; THEN &quot;Not Stated&quot;&#13;&#10;ELSEIF [legal_entity] = &quot;&quot; THEN &quot;Not Stated&quot;&#13;&#10;ELSE &quot;Yes&quot; END' />
      </column>
      <column caption='Calculation1' datatype='string' name='[Calculation_1458884860142309376]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='LEFT([id],15)' />
      </column>
      <column caption='Rolling Fy' datatype='boolean' name='[Calculation_1593148370162249728]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='DATETRUNC(&apos;month&apos;,[Calculation_131167342751051776]) &#13;&#10;&gt;=&#13;&#10;DATEADD(&apos;month&apos;,-IF MONTH(TODAY()) &lt; 4 THEN MONTH(TODAY()) + 20 ELSE MONTH(TODAY()) + 8 END,DATETRUNC(&apos;month&apos;,TODAY()))' />
