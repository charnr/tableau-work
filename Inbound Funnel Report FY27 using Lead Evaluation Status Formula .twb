            <column caption='Invalid Contact Details' datatype='string' name='[Calculation_1558526974754574336]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [status] = &quot;Closed&quot; &#13;&#10;and [reject_reason] = &quot;Invalid contact details&quot;&#13;&#10;THEN [id]&#13;&#10;ELSEIF [status] = &quot;Closed&quot;&#13;&#10;and [reject_disposition] = &quot;Invalid contact details + unable to update details&quot;&#13;&#10;THEN [id] ELSE NULL END' />
