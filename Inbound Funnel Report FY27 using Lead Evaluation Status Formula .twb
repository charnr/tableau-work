    <worksheet name='Inbound Conversion Weekly'>
      <layout-options>
        <title>
          <formatted-text>
            <run>IB Conv Weekly</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='lead (salesforce.lead) (salesforce)' name='federated.0zc1o901e3ofjl0zox69m0b5e5q7' />
          </datasources>
          <datasource-dependencies datasource='federated.0zc1o901e3ofjl0zox69m0b5e5q7'>
            <column aggregation='CountD' caption='Won' datatype='string' default-role='measure' default-type='quantitative' name='[Calculation_1141943991684665345]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [iswon] = TRUE THEN [id] ELSE NULL END' />
            </column>
            <column caption='COUNTD([Won])/COUNTD([Id])' datatype='real' name='[Calculation_1141943991684743171]' role='measure' type='quantitative' user:unnamed='SEA Inbound Leads (2)'>
              <calculation class='tableau' formula='COUNTD([Calculation_1141943991684665345])/COUNTD([id])' />
            </column>
            <column caption='Lead Created Date' datatype='date' name='[Calculation_165225817733201924]' role='dimension' type='ordinal'>
              <calculation class='tableau' formula='DATE([createddate])' />
            </column>
            <column caption='Crewe Inbound/Ipswich - Receiver Team' datatype='string' name='[Calculation_1686598103065382912]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [lead_owner_manager] IN (&quot;Lee Armstrong&quot;, &quot;Rob Scragg&quot;)&#13;&#10;THEN &quot;Crewe - Inbound&quot;&#13;&#10;ELSEIF ZN(INT([employee_id])) = 4918 &#13;&#10;OR ZN(INT([employee_id])) = 10689 &#13;&#10;OR ZN(INT([employee_id])) = 196 &#13;&#10;OR ZN(INT([employee_id])) = 6179&#13;&#10;THEN &quot;Ipswich - Receiver Team&quot;&#13;&#10;END' />
            </column>
            <column aggregation='Sum' caption='ISOweek' datatype='integer' name='[Calculation_256986658828546048]' role='dimension' type='ordinal'>
              <calculation class='tableau' formula='int(&#13;&#10;str(datepart(&apos;year&apos;, dateadd(&apos;week&apos;, INT(datediff(&apos;day&apos;, #1900-1-1#,[createddate])/7), #1900-1-4#)))+ &#13;&#10;IF INT((Datepart(&apos;dayofyear&apos;, (dateadd(&apos;day&apos;,INT(datediff(&apos;day&apos;, #1900-1-01#, [createddate])/7)*7  + 3,#1900-1-01#))) + 6)/7) &lt; 10 THEN&#13;&#10;    &apos;0&apos;&#13;&#10;ELSE&#13;&#10;    &apos;&apos;&#13;&#10;END +&#13;&#10;str(INT((Datepart(&apos;dayofyear&apos;, (dateadd(&apos;day&apos;,INT(datediff(&apos;day&apos;, #1900-1-01#, [createddate])/7)*7  + 3,#1900-1-01#))) + 6)/7))&#13;&#10;)' />
            </column>
            <column caption='Legal Entity RBS Fix' datatype='string' name='[Calculation_551690994224705536]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF CONTAINS(UPPER([description]), &apos;BUSINESS OWNER: NO&apos;) THEN &apos;Individual&apos;&#13;&#10;ELSEIF CONTAINS(UPPER([description]), &apos;BUSINESS OWNER: TIDAK&apos;) THEN &apos;Individual&apos;&#13;&#10;ELSE [legal_entity] END' />
            </column>
            <column aggregation='Sum' caption='MQL' datatype='integer' name='[Marketing Qualified Lead? (copy)_1607222149788565505]' role='dimension' type='ordinal'>
              <calculation class='tableau' formula='IF [Calculation_551690994224705536] = &apos;Individual&apos; AND [status] = &apos;Closed&apos; THEN 0&#13;&#10;ELSEIF [lead evaluation status formula] = &quot;MQL&quot; AND NOT UPPER([radius sales type]) = (&quot;UPSELL BUSINESS&quot;) THEN  1&#13;&#10;ELSE 0&#13;&#10;END' />
            </column>
            <column caption='Country Iso Code' datatype='string' name='[country_iso_code]' role='dimension' semantic-role='[Country].[ISO3166_2]' type='nominal' />
            <column caption='Createddate' datatype='datetime' name='[createddate]' role='dimension' type='ordinal' />
            <column-instance column='[Calculation_1141943991684665345]' derivation='CountD' name='[ctd:Calculation_1141943991684665345:qk]' pivot='key' type='quantitative' />
            <column-instance column='[id]' derivation='CountD' name='[ctd:id:qk]' pivot='key' type='quantitative' />
            <column caption='Description' datatype='string' name='[description]' role='dimension' type='nominal' />
            <column datatype='string' name='[employee_id]' role='dimension' type='nominal' />
            <column aggregation='CountD' caption='Id' datatype='string' default-role='measure' default-type='quantitative' name='[id]' role='dimension' type='nominal' />
            <column datatype='boolean' name='[iswon]' role='dimension' type='nominal' />
            <column datatype='string' name='[lead channel]' role='dimension' type='nominal' />
