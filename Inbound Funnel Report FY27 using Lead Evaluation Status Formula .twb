                      <expression op='IF ISNULL([Salesforce Cruise Apps SQL].[external_lead_id]) = TRUE THEN [Salesforce Cruise Apps SQL].[app_id] ELSE [Salesforce Cruise Apps SQL].[external_lead_id] END ' />
                    </expression>
                  </clause>
                  <relation join='left' type='join'>
                    <clause type='join'>
                      <expression op='='>
                        <expression op='LEFT([Lead SQL].[id],15)' />
                        <expression op='[Opportunity SQL].[lead_id]' />
                      </expression>
                    </clause>
                    <relation connection='redshift.16vdo2c1dsmv0b18u60ct011ix8q' name='Lead SQL' type='text'>SELECT &quot;lead&quot;.&quot;allocated_date_time&quot; AS &quot;allocated_date_time&quot;,
