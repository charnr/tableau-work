      </column>
      <column caption='Country Code Fix' datatype='string' name='[Calculation_165225817729740801]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [datatracker_source] = &quot;UKFuels - FY21-T1-001-016-BP Leads UK&quot; then &quot;gb&quot;&#13;&#10;ELSEIF&#13;&#10;[Calculation_806988769941692416] IN (&apos;1361499821&apos;, &#13;&#10;&apos;12197419392&apos;, &#13;&#10;&apos;13060083771&apos;, &#13;&#10;&apos;13060088805&apos;, &#13;&#10;&apos;13060090443&apos;, &#13;&#10;&apos;13060100607&apos;,&#13;&#10; &apos;13060110915&apos;, &#13;&#10;&apos;13060156551&apos;,&#13;&#10; &apos;13061893873&apos;, &#13;&#10;&apos;13061911879&apos;, &#13;&#10;&apos;13062457175&apos;, &#13;&#10;&apos;13472258385&apos;, &#13;&#10;&apos;19320764359&apos;, &#13;&#10;&apos;19572899037&apos;, &#13;&#10;&apos;19572948681&apos;, &#13;&#10;&apos;19573066929&apos;, &#13;&#10;&apos;19576625700&apos;,&#13;&#10; &apos;19576625703&apos;, &#13;&#10;&apos;19581258892&apos;, &#13;&#10;&apos;19584488816&apos;, &#13;&#10;&apos;19584488819&apos;,&#13;&#10; &apos;19584488822&apos;,&#13;&#10; &apos;19584897542&apos;,&#13;&#10; &apos;19584897545&apos;,&#13;&#10; &apos;19584897548&apos;,&#13;&#10; &apos;20445835866&apos;,&#13;&#10; &apos;20765056558&apos;,&#13;&#10; &apos;21085281009&apos;,&#13;&#10; &apos;21085281012&apos;,&#13;&#10; &apos;21085281015&apos;,&#13;&#10; &apos;21092199323&apos;,&#13;&#10; &apos;21092199326&apos;,&#13;&#10; &apos;21092199593&apos;)&#13;&#10; THEN &apos;ie&apos;&#13;&#10;ELSE STR([country_iso_code]) END' />
      </column>
      <column caption='Ireland Lead Channel Exclude' datatype='string' name='[Calculation_165225817731153923]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF NOT [lead_owner_manager] = &quot;Oltan Heffernan&quot;&#13;&#10;AND [lead channel] = &quot;Refer-a-friend&quot; &#13;&#10;THEN &quot;Refer-a-friend Outbound&quot;&#13;&#10;ELSEIF NOT [lead_owner_manager] = &quot;Oltan Heffernan&quot;&#13;&#10;AND [lead channel] = &quot;Divisional Referral&quot;&#13;&#10;THEN &quot;Referral Outbound&quot;&#13;&#10;ELSEIF NOT [lead_owner_manager] = &quot;Oltan Heffernan&quot;&#13;&#10;AND UPPER([lead sub channel]) = &quot;RADIUSCOMPARE.COM&quot;&#13;&#10;THEN &quot;radiuscompare.com Outbound&quot;&#13;&#10;ELSE [lead channel] END' />
      </column>
      <column caption='Lead Created Date' datatype='date' name='[Calculation_165225817733201924]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='DATE([createddate])' />
      </column>
      <column caption='UK Business?' datatype='string' name='[Calculation_165225817739374599]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [legal_entity] = &quot;Individual&quot; THEN &quot;No&quot;&#13;&#10;ELSEIF [Calculation_1032450282310459396] = &quot;iCompario&quot; AND [legal_entity] = &quot;&quot; AND [createddate] &gt;=#22/06/2023# THEN &quot;Yes&quot;&#13;&#10;ELSEIF [Calculation_1032450282310459396] &lt;&gt; &quot;iCompario&quot; AND [legal_entity]= &quot;&quot; THEN &quot;Not Stated&quot;&#13;&#10;ELSEIF [Calculation_1032450282310459396] = &quot;iCompario&quot; AND [legal_entity] = &quot;&quot; AND [createddate] &lt;#22/06/2023# THEN &quot;Not Stated&quot;&#13;&#10;ELSE &quot;Yes&quot; END' />
      </column>
      <column caption='Refer-a-friend tag' datatype='string' name='[Calculation_165225817739755528]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [lead channel] = &quot;Refer-a-friend&quot; AND [datatracker_source] = &quot;RAF - UK Fuels&quot; THEN &quot;Digital&quot;&#13;&#10;ELSEIF [lead channel]= &quot;Refer-a-friend&quot; AND [datatracker_source] = &quot;RAF - UK Fuels - Agent&quot; AND [lead_owner_manager] IN (&quot;Lee Armstrong&quot;,&quot;Shaun Cornes&quot;) Then &quot;Agent - Inbound&quot;&#13;&#10;ELSEIF [lead channel]= &quot;Refer-a-friend&quot; AND [datatracker_source] = &quot;RAF - UK Fuels - Agent&quot; THEN &quot;Agent - Outbound&quot;&#13;&#10;ELSEIF [lead channel] = &quot;Refer-a-friend&quot; THEN &quot;Not Specified&quot;&#13;&#10;ELSE NULL END' />
      </column>
      <column caption='Lead Owner' datatype='string' name='[Calculation_165225817752350729]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [ownerid] = &quot;00G4K000000FoZfUAK&quot; THEN &quot;iCompario Fuel Distribution&quot; &#13;&#10;ELSEIF [ownerid] = &quot;00G4K000000Oza7UAC&quot; THEN &quot;Inbound IE Fuel Queue&quot;&#13;&#10;ELSEIF [ownerid] = &quot;00G4K000001Q5dJUAS&quot; THEN &quot;Marketing Lead Queue&quot;&#13;&#10;ELSEIF [ownerid] = &quot;00G4K000000VZVFUA4&quot; THEN &quot;iCompario Distribution - Fuel&quot;&#13;&#10;ELSEIF [ownerid] = &quot;00G4K000000VZYKUA4&quot; THEN &quot;Fuel Online Applications&quot;&#13;&#10;ELSEIF [ownerid] = &quot;00G4K000000OG5QUAW&quot; THEN &quot;Fuel (Inbound) - Prev Rej Leads&quot;&#13;&#10;ELSEIF [ownerid] = &quot;00G4K000000PArnUAG&quot; THEN &quot;Telco New Inbound NI&quot;&#13;&#10;ELSEIF [ownerid] = &quot;00G4K000000VZVEUA4&quot; THEN &quot;AUTO-FUE-Inbound Fuel Leads&quot;&#13;&#10;ELSEIF [ownerid] = &quot;00G4K000000PArsUAG&quot; THEN &quot;Telco New Outbound NI&quot;&#13;&#10;ELSEIF [ownerid] = &quot;00G4K000001PXFYUA4&quot; THEN &quot;Vehicle Solutions Distribution&quot;&#13;&#10;ELSEIF [ownerid] = &quot;00G4K000000t4ztUAA&quot; THEN &quot;National Fuel Card Referrals (IE)&quot;&#13;&#10;ELSEIF [ownerid] = &quot;00G4K000000OG2iUAG&quot; THEN &quot;iCompario Distribution - Ireland Fuel&quot;&#13;&#10;ELSEIF [ownerid] = &quot;00G4K000001Q5dYUAS&quot; THEN &quot;Telco Mobile Pilot Holding Queue&quot;&#13;&#10;ELSEIF [ownerid] = &quot;00G4K000000Pi4RUAS&quot; THEN &quot;Telco New Outbound IE&quot;&#13;&#10;ELSEIF [ownerid] = &quot;00G8e000001EZq6EAG&quot; THEN &quot;(INTERNAL) Private Individuals DE&quot;&#13;&#10;ELSEIF [ownerid] = &quot;00G8e000001Ei7vEAC&quot; THEN &quot;(INTERNAL) Private Individuals UK&quot;&#13;&#10;ELSEIF [ownerid] = &quot;00G4K000000t8UyUAI&quot; THEN &quot;Bulk Delivery Referrals&quot;&#13;&#10;ELSEIF [ownerid] = &quot;00G4K000001Q641UAC&quot; THEN &quot;Crewe Fleet Queue&quot;&#13;&#10;ELSEIF [ownerid] = &quot;00G4K000001Q645UAC&quot; THEN &quot;MAN-FUE-Glasgow Fleet Queue&quot;&#13;&#10;ELSEIF [ownerid] = &quot;00G4K000001Q647UAC&quot;  THEN &quot;Ipswich Fleet Queue&quot;&#13;&#10;ELSEIF [ownerid] = &quot;00G4K000001Q64pUAC&quot; THEN &quot;MAN-FUE-York Fleet Queue&quot;&#13;&#10;ELSEIF [ownerid] = &quot;00G8e000001EkpaEAC&quot; THEN &quot;MAN-FUE-RAFUKFUELLEADS&quot;&#13;&#10;ELSEIF [ownerid] = &quot;00G8e000000MHU8EAO&quot; THEN &quot;AUTO-FUE-iCompario-Assisted Sales&quot;&#13;&#10;ELSEIF [ownerid] = &quot;00G8e000001XmchEAC&quot; THEN &quot;AUTO-FUE-SG Singapore Fuel Leads&quot;&#13;&#10;ELSEIF [ownerid] = &quot;00GTm000001shNZMAY&quot; THEN &quot;AUTO-FUE-MY-RBS-FACEBOOK&quot;&#13;&#10;ELSEIF [ownerid] = &quot;00GTm000003iEfCMAU&quot; THEN &quot;AUTO-FUE-MY-ServiceSales&quot;&#13;&#10;ELSEIF [ownerid] = &quot;00G8e000001XmcgEAC&quot; THEN &quot;AUTO-FUE-MY Malaysia Fuel Leads&quot;&#13;&#10;ELSEIF [ownerid] = &quot;00GTm000001shNaMAI&quot; THEN &quot;AUTO-FUE-MY-RBS-TIKTOK&quot;&#13;&#10;ELSEIF [ownerid] = &quot;00GTm000001shNbMAI&quot; THEN &quot;AUTO-FUE-SG-RBS-FACEBOOK&quot;&#13;&#10;&#13;&#10;&#13;&#10;ELSEIF [ownerid] = &quot;00G4K000000Oza7UAC&quot; THEN &quot;Inbound Fuel Lead IE&quot;&#13;&#10;ELSEIF [ownerid] = &quot;00G4K000000Pi1mUAC&quot; THEN &quot;Sub 3 Insurance Leads&quot;&#13;&#10;ELSEIF [ownerid] = &quot;00G4K000000PS4IUAG&quot; THEN &quot;Chargepoint Belgium Holding Queue&quot;&#13;&#10;ELSEIF [ownerid] = &quot;00G8e000000MGzeEAG&quot; THEN &quot;Energy Holding Queue IE&quot;&#13;&#10;ELSEIF [ownerid] = &quot;00G8e000001Ei7vEAC&quot; THEN &quot;(INTERNAL) Private Individuals UK&quot;&#13;&#10;ELSEIF [ownerid] = &quot;00G8e000001ErpKEAS&quot; THEN &quot;Private Inbound Fuel Leads IE&quot;&#13;&#10;ELSEIF [ownerid] = &quot;00G8e000001FOZ6EAO&quot; THEN &quot;MAN-FUE-IE PTNR TEAM-PARTNER LEADS&quot;&#13;&#10;ELSEIF [ownerid] = &quot;00GTm000002hUGEMA2&quot; THEN &quot;Auto-Fue-InboundIE-DCI&quot;&#13;&#10;ELSEIF [ownerid] = &quot;00GTm000002hUGFMA2&quot; THEN &quot;Auto-Fue-InboundIE-Icompario&quot;&#13;&#10;ELSEIF [ownerid] = &quot;00GTm000002hUGGMA2&quot; THEN &quot;Auto-Fue-InboundIE-MVF&quot;&#13;&#10;ELSEIF [ownerid] = &quot;00GTm000003iEfAMAU&quot; THEN &quot;AUTO-FUE-IE-ServiceSales&quot;&#13;&#10;ELSEIF [ownerid] = &quot;00GTm000003iEfDMAU&quot; THEN &quot;AUTO-FUE-NI-ServiceSales&quot;&#13;&#10;&#13;&#10;ELSEIF [ownerid] = &quot;00G8e000001FQ3xEAG&quot; THEN &quot;MAN-FUE-UK PTNR TEAM-PARTNER LEADS&quot;&#13;&#10;ELSEIF [ownerid] = &quot;00G8e000001EabZEAS&quot; THEN &quot;AUTO-RVS-GB Digital Leads&quot;&#13;&#10;ELSEIF [ownerid] = &quot;00GTm00000EQtf7MAD&quot; THEN &quot;AUTO-FUE-GB Inbound T2&quot;&#13;&#10;ELSEIF [ownerid] = &quot;00GTm00000ExjSTMAZ&quot; THEN &quot;MAN-FUE-IE-Partnerships Data Campaigns&quot;&#13;&#10;ELSEIF [ownerid] = &quot;00GTm0000032o3qMAA&quot; THEN &quot;AUTO-FUE-PT-Outbound-Partnerships&quot;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;ELSE [name] END' />
      </column>
      <column caption='Crewe Inbound/Ipswich - Receiver Team' datatype='string' name='[Calculation_1686598103065382912]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [lead_owner_manager] IN (&quot;Lee Armstrong&quot;, &quot;Rob Scragg&quot;)&#13;&#10;THEN &quot;Crewe - Inbound&quot;&#13;&#10;ELSEIF ZN(INT([employee_id])) = 4918 &#13;&#10;OR ZN(INT([employee_id])) = 10689 &#13;&#10;OR ZN(INT([employee_id])) = 196 &#13;&#10;OR ZN(INT([employee_id])) = 6179&#13;&#10;THEN &quot;Ipswich - Receiver Team&quot;&#13;&#10;END' />
      </column>
      <column aggregation='Sum' caption='Lead Owner Manager Inbound?' datatype='integer' name='[Calculation_191684517484224512]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='IF  [lead_owner_manager] = &apos;Shaun Cornes&apos; AND [Calculation_165225817733201924] &lt; DATE(&apos;2025-11-17&apos;) THEN 1&#13;&#10;ELSEIF [lead_owner_manager] = &apos;Shaun Cornes&apos; AND [Calculation_165225817733201924] &gt;= DATE(&apos;2025-11-17&apos;) THEN 0&#13;&#10;ELSEIF  [lead_owner_manager] IN (&apos;Lee Armstrong&apos;, &apos;Rob Scragg&apos;) THEN 1&#13;&#10;ELSE 0&#13;&#10;END' />
      </column>
      <column caption='Open Lead/Opp' datatype='string' name='[Calculation_1963287965255004160]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [status] IN (&quot;Allocated&quot;,&quot;Pending&quot;,&quot;Contacting&quot;,&quot;Working&quot;) THEN &apos;Open Lead&apos;&#13;&#10;ELSEIF [status] = &quot;Converted&quot; AND NOT [Sales Stage Fixed] IN (&quot;Closed Won&quot;,&quot;Closed Lost&quot;) THEN &apos;Open Opp&apos;&#13;&#10;ELSE NULL END' />
      </column>
      <column aggregation='Sum' caption='Lead Duration (days)' datatype='integer' name='[Calculation_197313973091667968]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='IF [close_date] = NULL THEN NULL &#13;&#10;ELSE DATEDIFF(&apos;day&apos;,[Calculation_131167342751051776],[close_date]) &#13;&#10;END' />
      </column>
      <column aggregation='Sum' caption='Verified Lead?' datatype='integer' name='[Calculation_197313973110644737]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='IF LOWER([radius sales type]) = &quot;upsell business&quot;&#13;&#10; THEN 0&#13;&#10;ELSEIF LOWER([radius sales type]) = &quot;existing business&quot;&#13;&#10; THEN 0&#13;&#10;ELSEIF&#13;&#10;[lead evaluation status formula] = &quot;Verified&quot; THEN 1&#13;&#10;ELSEIF&#13;&#10; [lead evaluation status formula] = &quot;MQL&quot; THEN 1&#13;&#10;ELSE 0&#13;&#10;END' />
      </column>
      <column aggregation='Sum' caption='Upsell/Existing Customer' datatype='integer' name='[Calculation_197313973113610243]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='IF [radius sales type] = &quot;Upsell Business&quot; AND [duplicate_of_account] &lt;&gt; &quot;&quot; THEN 1&#13;&#10;ELSEIF [status] = &quot;Closed&quot; AND [reject_disposition] = &quot;Existing Customer&quot; AND [duplicate_of_account] &lt;&gt; &quot;&quot; THEN 1&#13;&#10;ELSE 0&#13;&#10;END' />
      </column>
      <column aggregation='Sum' caption='Open Lead?' datatype='integer' name='[Calculation_197313973123813380]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='IF LOWER([status]) = &apos;closed&apos; THEN 0&#13;&#10;ELSEIF &#13;&#10;LOWER([status]) = &apos;allocated&apos; THEN 1&#13;&#10;ELSEIF&#13;&#10;LOWER([status]) = &apos;contacting&apos; THEN 1&#13;&#10;ELSEIF&#13;&#10;LOWER([status]) = &apos;converted&apos; THEN 0&#13;&#10;ELSEIF&#13;&#10;LOWER([status]) = &apos;marketing lead&apos; THEN 0&#13;&#10;ELSEIF&#13;&#10;LOWER([status]) = &apos;pending&apos; THEN 1&#13;&#10;ELSEIF&#13;&#10;LOWER([status]) = &apos;working&apos; THEN 1&#13;&#10;ELSEIF&#13;&#10;LOWER([status]) = &apos;rejected&apos; THEN 0&#13;&#10;&#13;&#10;&#13;&#10;END' />
      </column>
      <column caption='Organic' datatype='string' name='[Calculation_229402109252886528]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF ISNULL([Medium]) OR TRIM([Medium]) = &quot;&quot; OR TRIM([Medium]) = &quot;null&quot; OR TRIM([Medium]) = &quot;Blank&quot; OR TRIM([Medium]) = &quot;Medium&quot; OR TRIM([Medium]) = &quot;Organic&quot;&#13;&#10;OR TRIM([Medium]) = &quot;organic&quot;&#13;&#10;OR TRIM([Medium]) = &quot;Facebook Organic&quot;&#13;&#10;THEN &quot;1&quot;&#13;&#10;ELSE &quot;0&quot;&#13;&#10;END' />
      </column>
      <column aggregation='Sum' caption='ISOweek' datatype='integer' name='[Calculation_256986658828546048]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='int(&#13;&#10;str(datepart(&apos;year&apos;, dateadd(&apos;week&apos;, INT(datediff(&apos;day&apos;, #1900-1-1#,[createddate])/7), #1900-1-4#)))+ &#13;&#10;IF INT((Datepart(&apos;dayofyear&apos;, (dateadd(&apos;day&apos;,INT(datediff(&apos;day&apos;, #1900-1-01#, [createddate])/7)*7  + 3,#1900-1-01#))) + 6)/7) &lt; 10 THEN&#13;&#10;    &apos;0&apos;&#13;&#10;ELSE&#13;&#10;    &apos;&apos;&#13;&#10;END +&#13;&#10;str(INT((Datepart(&apos;dayofyear&apos;, (dateadd(&apos;day&apos;,INT(datediff(&apos;day&apos;, #1900-1-01#, [createddate])/7)*7  + 3,#1900-1-01#))) + 6)/7))&#13;&#10;)' />
      </column>
      <column aggregation='Sum' caption='Outbound RAB Lead?' datatype='integer' name='[Calculation_340866254524534784]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='IF [Calculation_165225817739755528] = &quot;Agent - Outbound&quot; THEN 0 ELSE 1 END' />
      </column>
      <column aggregation='Sum' caption='Valid Lead (SEA)?' datatype='integer' name='[Calculation_452611798908743680]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='IF [Loss Reason Valid] = &quot;Invalid&quot; THEN 0&#13;&#10;ELSEIF [Secondary Loss Reason Valid?] = &quot;Invalid&quot; THEN 0&#13;&#10;ELSE 1 END' />
      </column>
