              <calculation class='tableau' formula='IF [status] = &quot;Closed&quot;&#13;&#10;AND [reject_disposition] = &quot;Existing Customer&quot;&#13;&#10;THEN [id]&#13;&#10;ElSE NULL &#13;&#10;END' />
            </column>
            <column caption='Business Leads' datatype='string' name='[Calculation_1558526974755291139]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [reject_disposition] = &quot;Individual&quot;&#13;&#10;THEN NULL ELSE [id]&#13;&#10;END' />
            </column>
            <column caption='Unique Companies' datatype='string' name='[Calculation_1558526974755467268]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [status] = &quot;Closed&quot; &#13;&#10;AND [reject_disposition] = &quot;Individual&quot;&#13;&#10;THEN NULL&#13;&#10;ELSEIF [status] = &quot;Closed&quot;&#13;&#10;and [reject_disposition] = &quot;Invalid contact details + unable to update details&quot;&#13;&#10;THEN NULL&#13;&#10;ELSEIF [status] = &quot;Closed&quot;&#13;&#10;and [reject_reason] = &quot;Invalid contact details&quot;&#13;&#10;THEN NULL&#13;&#10;ELSEIF [status] = &quot;Closed&quot;&#13;&#10;and [reject_disposition] = &quot;Existing Customer&quot;&#13;&#10;THEN NULL&#13;&#10;ELSE UPPER([company])&#13;&#10;END' />
            </column>
            <column caption='COUNTD([Unique Companies])/COUNTD([Business Leads])' datatype='real' name='[Calculation_1558526974758113287]' role='measure' type='quantitative' user:unnamed='ProjX Prev Month (2)'>
