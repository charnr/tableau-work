    <worksheet lock-updates='true' name='UK Inbound Leads'>
      <table>
        <view>
          <datasources>
            <datasource caption='lead (salesforce.lead) (salesforce)' name='federated.0zc1o901e3ofjl0zox69m0b5e5q7' />
          </datasources>
          <datasource-dependencies datasource='federated.0zc1o901e3ofjl0zox69m0b5e5q7'>
            <column caption='UK Lead Channel Fix' datatype='string' name='[Calculation_1032450282310459396]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [lead channel] = &quot;3rd Party Provider&quot; THEN [lead sub channel]&#13;&#10;ELSEIF [lead channel]  = &quot;Social Media&quot; THEN  [lead sub channel]&#13;&#10;ELSEIF CONTAINS(UPPER([datatracker_source]),&quot;RADIUS.COM&quot;) THEN &quot;radius.com&quot;&#13;&#10;ELSEIF UPPER([lead channel]) = &quot;INBOUND&quot; THEN &quot;Inbound (Call/Email)&quot;&#13;&#10;ELSEIF UPPER([lead channel]) = &quot;WEBSITE&quot; Then [lead sub channel]&#13;&#10;ELSE [lead channel] END' />
            </column>
            <column caption='Applied for Diesel LOD' datatype='integer' name='[Calculation_1032450282311340040]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED [id] :MAX([monthly_diesel])}' />
            </column>
            <column caption='Applied for Petrol LOD' datatype='integer' name='[Calculation_1032450282311401481]' role='measure' type='quantitative'>
