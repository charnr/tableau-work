              <calculation class='tableau' formula='IF [radius sales type] = &apos;Upsell Business&apos; THEN 0&#13;&#10;ELSEIF [radius sales type] = &apos;Existing Business&apos; THEN 0&#13;&#10;&#13;&#10;ELSEIF &#13;&#10;LOWER([legal_entity]) = &apos;individual&apos; OR &#13;&#10;LOWER([reject_disposition]) = &apos;private individual&apos; OR&#13;&#10;LOWER([reject_disposition]) = &apos;individual&apos; OR  &#13;&#10;LOWER([reject_reason]) = &apos;consumer lead&apos; &#13;&#10;THEN 0&#13;&#10;&#13;&#10;ELSEIF &#13;&#10;LOWER([status]) = &apos;closed&apos; AND &#13;&#10;LOWER([reject_reason]) = &apos;duplicate record&apos;&#13;&#10;THEN 0&#13;&#10;&#13;&#10;ELSEIF &#13;&#10;LOWER([status]) = &apos;closed&apos; &#13;&#10;AND &#13;&#10;(LOWER([reject_disposition]) = &apos;existing customer&apos; OR LOWER([reject_disposition]) = &apos;existing prospect&apos;)&#13;&#10;THEN 0&#13;&#10;&#13;&#10;ELSE [Calculation_1182194924152467462]&#13;&#10;END' />
